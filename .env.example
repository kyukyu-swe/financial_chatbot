# LLM Provider: "ollama" (local, default) or "openai"
# Set to "openai" to use OpenAI's API instead of a local Ollama instance.
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
# The base URL of your running Ollama server.
OLLAMA_URL=http://localhost:11434
# The Ollama model tag to use (e.g. gemma3:1b, llama3.2, mistral).
OLLAMA_MODEL=gemma3:1b

# OpenAI settings (used when LLM_PROVIDER=openai)
# Your OpenAI secret API key — keep this private, never commit it.
OPENAI_API_KEY=sk-your-openai-api-key-here
# The OpenAI chat model to use (e.g. gpt-4o-mini, gpt-4o).
OPENAI_MODEL=gpt-4o-mini

# FastAPI backend URL consumed by the Streamlit frontend.
API_BASE=http://localhost:8000

# Default merchant ID pre-selected in the Streamlit sidebar.
# Valid values: mch_001 – mch_005
SESSION_MERCHANT_ID=mch_001
